{
  "name": "acme",
  "version": "0.0.0",
  "private": true,
  "scripts": {
    "build": "turbo build",
    "dev": "turbo dev",
    "lint": "turbo lint",
    "type-check": "turbo type-check",
    "format": "prettier --write \"**/*.{ts,tsx,js,json,md,css,html,yml,yaml}\"",
    "format:check": "prettier --check \"**/*.{ts,tsx,js,json,md,css,html,yml,yaml}\"",
    "prepare": "husky",
    "infra:up": "docker compose up -d",
    "infra:down": "docker compose down",
    "db:migrate": "pnpm --filter @acme/server db:migrate"
  },
  "devDependencies": {
    "@commitlint/cli": "^20.4.2",
    "@commitlint/config-conventional": "^20.4.2",
    "@typescript-eslint/eslint-plugin": "^8.21.0",
    "@typescript-eslint/parser": "^8.21.0",
    "eslint": "^9.19.0",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.0.1",
    "husky": "^9.1.7",
    "lint-staged": "^15.4.3",
    "prettier": "^3.4.2",
    "turbo": "^2.3.3",
    "typescript": "^5.7.3"
  },
  "lint-staged": {
    "*.{ts,tsx}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{js,json,md,css,html,yml,yaml}": [
      "prettier --write"
    ]
  },
  "engines": {
    "node": ">=20",
    "pnpm": ">=9"
  },
  "packageManager": "pnpm@10.30.3",
  "pnpm": {
    "overrides": {
      "react-native-worklets": "0.5.1",
      "better-auth": "1.5.4",
      "@better-auth/core": "1.5.4",
      "@better-auth/drizzle-adapter": "1.5.4",
      "@better-auth/expo": "1.5.4",
      "@better-auth/kysely-adapter": "1.5.4",
      "@better-auth/memory-adapter": "1.5.4",
      "@better-auth/mongo-adapter": "1.5.4",
      "@better-auth/prisma-adapter": "1.5.4",
      "@better-auth/telemetry": "1.5.4",
      "react": "19.1.0",
      "react-dom": "19.1.0",
      "@types/react": "19.1.17",
      "@types/react-dom": "19.1.11"
    },
    "onlyBuiltDependencies": [
      "esbuild",
      "prisma",
      "@prisma/engines",
      "@prisma/client",
      "sharp"
    ]
  }
}
