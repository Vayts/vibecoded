# ── Local dev (docker-compose) ────────────────────────────────
DATABASE_URL=postgresql://acme:acme_password@localhost:5432/acme

# MinIO local (S3-compatible substitute for GCS)
GCS_BUCKET=acme-images
GCS_ENDPOINT=http://localhost:9000
GCS_ACCESS_KEY=minioadmin
GCS_SECRET_KEY=minioadmin123

# ── Auth ──────────────────────────────────────────────────────
BETTER_AUTH_URL=http://localhost:3000
BETTER_AUTH_SECRET=change-me-in-production-32-chars-min
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-client-secret

# Apple OAuth — required for Apple Sign In
# APPLE_CLIENT_ID: the Service ID you created in Apple Developer (for OAuth web flow)
# APPLE_CLIENT_SECRET: signed JWT generated from your Apple private key
# APPLE_APP_BUNDLE_ID: iOS app bundle identifier (ai.sealsync.acme) — used to verify
#   native Apple Sign In identity tokens from expo-apple-authentication
APPLE_CLIENT_ID=your-apple-service-id
APPLE_CLIENT_SECRET=your-apple-client-secret-jwt
APPLE_APP_BUNDLE_ID=ai.sealsync.acme

# ── AI ────────────────────────────────────────────────────────
OPENAI_API_KEY=sk-...

# ── LangSmith (optional) ─────────────────────────────────────
LANGSMITH_TRACING=true
LANGSMITH_ENDPOINT=https://api.smith.langchain.com
LANGSMITH_API_KEY=lsv2_...
LANGSMITH_PROJECT=acme

# ── Server ────────────────────────────────────────────────────
PORT=3000
# Comma-separated list of additional trusted origins.
# Add the Expo app URL scheme so OAuth deep-link callbacks work (expo plugin
# already adds exp:// in development, but standalone builds need acme://).
TRUSTED_ORIGINS=http://localhost:8081

# ── Error Tracking (optional) ─────────────────────────────────
SENTRY_DSN=
